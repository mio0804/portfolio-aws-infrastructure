# Flask設定
FLASK_APP=backend.app
FLASK_ENV=development

# データベース設定（開発環境）
DATABASE_URL=postgresql://animalog:animalog@db:5432/animalog

# RDS設定（本番環境用）
# 開発環境: USE_RDS=falseでローカルPostgreSQLを使用
# 本番環境: USE_RDS=trueでRDS + Systems Managerを使用（タスク定義で設定）
USE_RDS=false
AWS_SSM_PARAMETER_NAME=your-parameter-name
RDS_ENDPOINT=your-rds-endpoint
RDS_DATABASE=your-rds-database
RDS_USERNAME=your-rds-username

# S3設定
# 開発環境: AWS_ACCESS_KEY_IDとAWS_SECRET_ACCESS_KEYを設定
# 本番環境: IAMロールを使用する場合はAWS_ACCESS_KEY_IDを未設定にする（タスク定義で設定）
USE_S3=false
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=region
S3_BUCKET_NAME=your-bucket-name

# Cognito設定
# 開発環境: USE_COGNITO=falseでCognitoを使用しない
# 本番環境: USE_COGNITO=trueでCognitoを使用（タスク定義で設定）
USE_COGNITO=false
COGNITO_REGION=ap-northeast-1
COGNITO_USER_POOL_ID=your-user-pool-id
COGNITO_APP_CLIENT_ID=your-app-client-id
COGNITO_DOMAIN=your-cognito-domain.auth.ap-northeast-1.amazoncognito.com
COGNITO_REDIRECT_URI=http://localhost:3000/callback
COGNITO_LOGOUT_URI=http://localhost:3000/login

# 開発用モックユーザー
MOCK_USER_ID=test-user-123
MOCK_USER_EMAIL=test@example.com

# アップロードフォルダ設定（ローカル環境用）
UPLOAD_FOLDER=/workspace/uploads
# アップロード設定（16MB）
MAX_CONTENT_LENGTH=16777216 

# CORS設定
# 開発環境: デフォルト値を使用（設定不要）
# 本番環境: フロントエンドのURLを指定（タスク定義で設定）
# 複数環境の場合: CORS_ORIGINS=https://app.example.com,https://staging.app.example.com
CORS_ORIGINS=https://your-frontend-domain.com